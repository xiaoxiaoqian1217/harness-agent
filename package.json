{
  "name": "harness-ai-agent",
  "version": "1.0.0",
  "description": "Harness-style AI agent for full-stack application generation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "typecheck": "tsc --noEmit",
    "playwright:install": "playwright install"
  },
  "bin": {
    "harness-agent": "./dist/index.js"
  },
  "keywords": ["ai", "agent", "code-generation", "harness", "claude"],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "simple-git": "^3.22.0",
    "playwright": "^1.42.0",
    "zod": "^3.22.0",
    "winston": "^3.11.0",
    "glob": "^10.3.0",
    "fs-extra": "^11.2.0",
    "yaml": "^2.3.0",
    "chalk": "^5.3.0",
    "inquirer": "^9.2.0",
    "open": "^10.0.0",
    "sharp": "^0.33.0",
    "axios": "^1.6.0",
    "dotenv": "^16.4.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/fs-extra": "^11.0.0",
    "@types/glob": "^8.1.0",
    "@types/inquirer": "^9.0.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "prettier": "^3.2.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
