# Agent Configuration
PLANNER_TEMPERATURE=0.1
GENERATOR_TEMPERATURE=0.7
EVALUATOR_TEMPERATURE=0.3

# Quality Thresholds
MIN_PASS_SCORE=85
PIVOT_THRESHOLD=60
MAX_ITERATIONS=5

# Project Configuration
DEFAULT_WORKSPACE=./workspace
GIT_USER_NAME="Harness AI Agent"
